{
  "appId": "com.metflix.app",
  "appName": "Metflix",
  "webDir": "out",
  "bundledWebRuntime": false,
  "android": {
    "buildOptions": {
      "releaseType": "APK"
    }
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#0a0a0a",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#0a0a0a",
      "overlaysWebView": true
    }
  }
}
